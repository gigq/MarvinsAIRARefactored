RewriteEngine On

# 1) If the request maps to a real file or directory, serve it unchanged
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 2) Pretty Markdown URL:
#    /help/something   →   help.html?page=something
#
#    Captures any path segment that is NOT a file and rewrites it.
RewriteRule ^([^/]+)$ help.html?page=$1 [L,QSA]

# 3) Handle base /help or /help/
#    /help/   → help.html
RewriteRule ^$ help.html [L,QSA]
