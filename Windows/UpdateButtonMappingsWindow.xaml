<Window x:Class="MarvinsALMUARefactored.Windows.UpdateButtonMappingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:windows="clr-namespace:MarvinsALMUARefactored.Windows"
        xmlns:controls="clr-namespace:MarvinsALMUARefactored.Controls"
        xmlns:components="clr-namespace:MarvinsALMUARefactored.Components"
        xmlns:datacontext="clr-namespace:MarvinsALMUARefactored.DataContext"
        mc:Ignorable="d"
        Title="{Binding Localization[UpdateButtonMappings]}"
        Icon="/Artwork/AppIcon/malmua-universal.ico"
        Width="800"
        MaxHeight="600"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterOwner"
        Closed="Window_Closed">

    <Window.DataContext>
        <Binding Source="{x:Static datacontext:DataContext.Instance}" />
    </Window.DataContext>

    <StackPanel Margin="40,20,40,40">

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Margin="0,0,0,40">

            <StackPanel x:Name="StackPanel" />

        </ScrollViewer>

        <StackPanel>

            <Grid HorizontalAlignment="Center">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <controls:MairaButton Grid.Column="0"
                                      Icon="/MarvinsALMUARefactored;component/Artwork/Buttons/plus-large.png"
                                      Click="Plus_MairaButton_Click" />

                <controls:MairaButton Grid.Column="2"
                                      Icon="/MarvinsALMUARefactored;component/Artwork/Buttons/set.png"
                                      Click="ThumbsUp_MairaButton_Click" />

            </Grid>

        </StackPanel>

    </StackPanel>

</Window>
