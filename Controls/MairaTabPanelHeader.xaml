<UserControl x:Class="MarvinsAIRARefactored.Controls.MairaTabPanelHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MarvinsAIRARefactored.Controls"
             mc:Ignorable="d">
    
    <Grid Margin="0,0,0,10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock x:Name="TextBlock" Grid.Column="0" Text="{Binding HeaderText, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="#979797" FontFamily="pack://application:,,,/MarvinsAIRARefactored;component/Fonts/#Aptos Narrow" FontSize="40"/>

        <Border x:Name="Status_Border" Grid.Column="1" BorderThickness="2" CornerRadius="8" Padding="10,1" VerticalAlignment="Center">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="Status_TextBlock_1" Grid.Column="0" d:Text="Mazda MX-5 Cup" Text="{Binding StatusText1, RelativeSource={RelativeSource AncestorType=UserControl}}" FontFamily="pack://application:,,,/MarvinsAIRARefactored;component/Fonts/#Aptos Narrow" FontSize="20"/>
                <Border x:Name="Status_Divider_1" Grid.Column="1" BorderThickness="1,0,0,0" Margin="8,1" VerticalAlignment="Stretch"/>
                <TextBlock x:Name="Status_TextBlock_2" Grid.Column="2" d:Text="Virginia International Raceway" Text="{Binding StatusText2, RelativeSource={RelativeSource AncestorType=UserControl}}" FontFamily="pack://application:,,,/MarvinsAIRARefactored;component/Fonts/#Aptos Narrow" FontSize="20"/>
                <Border x:Name="Status_Divider_2" Grid.Column="3" BorderThickness="1,0,0,0" Margin="8,1" VerticalAlignment="Stretch"/>
                <TextBlock x:Name="Status_TextBlock_3" Grid.Column="4" d:Text="Grand Course" Text="{Binding StatusText3, RelativeSource={RelativeSource AncestorType=UserControl}}" FontFamily="pack://application:,,,/MarvinsAIRARefactored;component/Fonts/#Aptos Narrow" FontSize="20"/>
                <Border x:Name="Status_Divider_3" Grid.Column="5" BorderThickness="1,0,0,0" Margin="8,1" VerticalAlignment="Stretch"/>
                <TextBlock x:Name="Status_TextBlock_4" Grid.Column="6" d:Text="Dry" Text="{Binding StatusText4, RelativeSource={RelativeSource AncestorType=UserControl}}" FontFamily="pack://application:,,,/MarvinsAIRARefactored;component/Fonts/#Aptos Narrow" FontSize="20"/>
            </Grid>

        </Border>

    </Grid>

</UserControl>
