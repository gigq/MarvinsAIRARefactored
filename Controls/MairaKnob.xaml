<UserControl x:Class="MarvinsAIRARefactored.Controls.MairaKnob"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:MarvinsAIRARefactored.Controls"
             mc:Ignorable="d">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="Label_TextBlock" d:Text="Just a test!"
                   Foreground="#ffffff"
                   FontFamily="pack://application:,,,/MarvinsAIRARefactored;component/Fonts/#Aptos Narrow"
                   FontSize="20"
                   Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   PreviewMouseRightButtonDown="Label_PreviewMouseRightButtonDown"/>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" x:Name="Curve_Image"
                   Width="48"
                   Height="48"
                   Visibility="Collapsed"/>
            
            <TextBlock Grid.Column="1" x:Name="Value_TextBlock"
                       FontSize="30"
                       FontFamily="pack://application:,,,/MarvinsAIRARefactored;component/Fonts/#Fira Code"
                       Foreground="#ff5b2e"
                       Text="{Binding ValueString, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       PreviewMouseRightButtonDown="Value_Label_PreviewMouseRightButtonDown"
                       PreviewMouseRightButtonUp="Value_Label_PreviewMouseRightButtonUp"
                       MouseLeave="Value_Label_MouseLeave"/>

            <Grid Grid.Column="2">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <controls:MairaMappableButton Grid.Column="0"
                                              Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/minus-small.png"
                                              IconWidth="32"
                                              IconHeight="32"
                                              DefaultFrame="/MarvinsAIRARefactored;component/Artwork/Buttons/knob-minus-default.png"
                                              MappedFrame="/MarvinsAIRARefactored;component/Artwork/Buttons/knob-minus-mapped.png"
                                              PressedFrame="/MarvinsAIRARefactored;component/Artwork/Buttons/knob-minus-pressed.png"
                                              Click="Minus_MairaMappableButton_Click"
                                              ButtonMappings="{Binding PlusButtonMappings, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

                <controls:MairaButton Grid.Column="1"
                                      Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/drag-small.png"
                                      IconWidth="52"
                                      IconHeight="32"
                                      DefaultFrame="/MarvinsAIRARefactored;component/Artwork/Buttons/knob-middle-default.png"
                                      PressedFrame="/MarvinsAIRARefactored;component/Artwork/Buttons/knob-middle-pressed.png"/>
                
                <controls:MairaMappableButton Grid.Column="2"
                                              Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/plus-small.png"
                                              IconWidth="32"
                                              IconHeight="32"
                                              DefaultFrame="/MarvinsAIRARefactored;component/Artwork/Buttons/knob-plus-default.png"
                                              MappedFrame="/MarvinsAIRARefactored;component/Artwork/Buttons/knob-plus-mapped.png"
                                              PressedFrame="/MarvinsAIRARefactored;component/Artwork/Buttons/knob-plus-pressed.png"
                                              Click="Plus_MairaMappableButton_Click"
                                              ButtonMappings="{Binding PlusButtonMappings, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

            </Grid>

        </Grid>




    </Grid>

</UserControl>
