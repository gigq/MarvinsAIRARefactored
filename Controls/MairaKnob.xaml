<UserControl x:Class="MarvinsAIRARefactored.Controls.MairaKnob"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:MarvinsAIRARefactored.Controls"
             mc:Ignorable="d"
             d:Width="300"
             d:Height="Auto">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label x:Name="Label" Grid.Row="0" Content="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" HorizontalAlignment="Center" PreviewMouseRightButtonDown="Label_PreviewMouseRightButtonDown"/>

        <Border Grid.Row="1" BorderBrush="White" BorderThickness="2" Background="#FF111111" Padding="10,4,10,4" CornerRadius="4">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,10,0">

                    <Image x:Name="ButtonFace_Default_Image" Source="/MarvinsAIRARefactored;component/Artwork/Button/button_face_default.png" Width="48" Height="48"/>
                    <Image x:Name="ButtonFace_Pressed_Image" Source="/MarvinsAIRARefactored;component/Artwork/Button/button_face_pressed.png" Width="48" Height="48" Visibility="Hidden"/>

                    <Image Source="/MarvinsAIRARefactored;component/Artwork/Button/button_border_default.png" Width="48" Height="48"/>

                    <Image x:Name="ButtonIcon_Image" Source="/MarvinsAIRARefactored;component/Artwork/ButtonIcons/button_icon_knob.png" Width="48" Height="48" RenderTransformOrigin="0.5,0.5" MouseDown="KnobImage_Image_MouseDown" MouseMove="KnobImage_Image_MouseMove" MouseUp="KnobImage_Image_MouseUp" LostMouseCapture="KnobImage_Image_LostMouseCapture" Cursor="SizeWE" RenderOptions.BitmapScalingMode="HighQuality"/>

                </Grid>

                <Grid Grid.Column="1">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0" x:Name="Curve_Image" Width="48" Height="48" Visibility="Collapsed"/>
                    <Label Grid.Column="1" x:Name="Value_Label" FontSize="32" FontFamily="pack://application:,,,/MarvinsAIRARefactored;component/Fonts/#Fira Code" Foreground="SkyBlue" Padding="0" Margin="0" Content="{Binding ValueString, RelativeSource={RelativeSource AncestorType=UserControl}}" HorizontalContentAlignment="Center" PreviewMouseRightButtonDown="Value_Label_PreviewMouseRightButtonDown" PreviewMouseRightButtonUp="Value_Label_PreviewMouseRightButtonUp" MouseLeave="Value_Label_MouseLeave"/>

                </Grid>

                <StackPanel Grid.Column="2" Margin="10,0,0,0">

                    <controls:MairaMappableButton Title="" ButtonIcon="/MarvinsAIRARefactored;component/Artwork/ButtonIcons/button_icon_plus.png" Width="24" Height="24" Padding="0" Margin="1" Click="Plus_MairaMappableButton_Click" Small="True" ButtonMappings="{Binding PlusButtonMappings, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    <controls:MairaMappableButton Title="" ButtonIcon="/MarvinsAIRARefactored;component/Artwork/ButtonIcons/button_icon_minus.png" Width="24" Height="24" Padding="0" Margin="1" Click="Minus_MairaMappableButton_Click" Small="True" ButtonMappings="{Binding MinusButtonMappings, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</UserControl>
