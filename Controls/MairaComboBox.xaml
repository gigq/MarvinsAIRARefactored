<UserControl x:Class="MarvinsAIRARefactored.Controls.MairaComboBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:MarvinsAIRARefactored.Controls"
             mc:Ignorable="d">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TextBlock" d:Text="Steering Device"
                   Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Foreground="#ffffff"
                   FontFamily="pack://application:,,,/MarvinsAIRARefactored;component/Fonts/#Aptos Narrow"
                   FontSize="20"
                   PreviewMouseRightButtonDown="TextBlock_PreviewMouseRightButtonDown"/>

        <ComboBox Grid.Row="1" x:Name="ComboBox"
                  DisplayMemberPath="Value"
                  SelectedValuePath="Key"
                  ItemsSource="{Binding ItemsSource, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  SelectedValue="{Binding SelectedValue, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  IsEditable="False"/>

    </Grid>

</UserControl>
