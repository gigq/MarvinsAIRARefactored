<UserControl x:Class="MarvinsAIRARefactored.Controls.MairaDualSlider"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MarvinsAIRARefactored.Controls"
             mc:Ignorable="d"
             d:DesignHeight="450">

    <Grid x:Name="Grid">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Grid.ColumnSpan="4"
                   Style="{StaticResource MairaTextBlockStyle}"
                   Text="{Binding LeftValueString, ElementName=Root, FallbackValue=250}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,5" />

        <Border Grid.Row="1"
                Grid.Column="1"
                BorderThickness="0"
                BorderBrush="Transparent"
                CornerRadius="5,0,0,5"
                Width="5"
                HorizontalAlignment="Right">

            <Border.Background>
                <LinearGradientBrush StartPoint="0,0"
                                     EndPoint="0,1">
                    <GradientStop Color="#ff5b2e"
                                  Offset="0" />
                    <GradientStop Color="#983418"
                                  Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

        </Border>

        <Border Grid.Row="1"
                Grid.Column="2"
                BorderThickness="0"
                BorderBrush="Transparent"
                CornerRadius="0,5,5,0"
                Width="5"
                HorizontalAlignment="Left">

            <Border.Background>
                <LinearGradientBrush StartPoint="0,0"
                                     EndPoint="0,1">
                    <GradientStop Color="#a8cdff"
                                  Offset="0" />
                    <GradientStop Color="#426da8"
                                  Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

        </Border>

        <Image x:Name="LeftDragHandle_Image"
               Grid.Row="1"
               Grid.Column="0"
               Grid.ColumnSpan="2"
               Source="/MarvinsAIRARefactored;component/Artwork/Misc/left-drag-handle.png"
               Width="12"
               Height="20"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Cursor="Hand" />

        <Image x:Name="RightDragHandle_Image"
               Grid.Row="1"
               Grid.Column="2"
               Grid.ColumnSpan="2"
               Source="/MarvinsAIRARefactored;component/Artwork/Misc/right-drag-handle.png"
               Width="12"
               Height="20"
               HorizontalAlignment="Left"
               VerticalAlignment="Bottom"
               Cursor="Hand" />

        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Grid.ColumnSpan="4"
                   Style="{StaticResource MairaTextBlockStyle}"
                   Text="{Binding RightValueString, ElementName=Root, FallbackValue=100%}"
                   HorizontalAlignment="Center"
                   Margin="0,5,0,0" />

    </Grid>

</UserControl>
