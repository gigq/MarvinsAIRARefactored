<UserControl x:Class="MarvinsALMUARefactored.Pages.DebugPage"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MarvinsALMUARefactored.Pages"
             xmlns:controls="clr-namespace:MarvinsALMUARefactored.Controls"
             xmlns:datacontext="clr-namespace:MarvinsALMUARefactored.DataContext"
             mc:Ignorable="d"
             d:DesignWidth="800">

    <UserControl.DataContext>
        <Binding Source="{x:Static datacontext:DataContext.Instance}" />
    </UserControl.DataContext>

    <StackPanel>

        <controls:MairaGroupBox Label="Debug Variables">

            <StackPanel>

                <TextBlock x:Name="Debug_TextBlock_1"
                           Style="{StaticResource MairaTextBlockStyle}"
                           Text="Test 1" />

                <TextBlock x:Name="Debug_TextBlock_2"
                           Style="{StaticResource MairaTextBlockStyle}"
                           Text="Test 2" />

                <TextBlock x:Name="Debug_TextBlock_3"
                           Style="{StaticResource MairaTextBlockStyle}"
                           Text="Test 3" />

                <TextBlock x:Name="Debug_TextBlock_4"
                           Style="{StaticResource MairaTextBlockStyle}"
                           Text="Test 4" />

                <TextBlock x:Name="Debug_TextBlock_5"
                           Style="{StaticResource MairaTextBlockStyle}"
                           Text="Test 5" />

                <TextBlock x:Name="Debug_TextBlock_6"
                           Style="{StaticResource MairaTextBlockStyle}"
                           Text="Test 6" />

                <TextBlock x:Name="Debug_TextBlock_7"
                           Style="{StaticResource MairaTextBlockStyle}"
                           Text="Test 7" />

                <TextBlock x:Name="Debug_TextBlock_8"
                           Style="{StaticResource MairaTextBlockStyle}"
                           Text="Test 8" />

                <TextBlock x:Name="Debug_TextBlock_9"
                           Style="{StaticResource MairaTextBlockStyle}"
                           Text="Test 9" />

                <TextBlock x:Name="Debug_TextBlock_10"
                           Style="{StaticResource MairaTextBlockStyle}"
                           Text="Test 10" />

                <TextBlock x:Name="Debug_TextBlock_11"
                           Style="{StaticResource MairaTextBlockStyle}"
                           Text="Test 11" />

                <TextBlock x:Name="Debug_TextBlock_12"
                           Style="{StaticResource MairaTextBlockStyle}"
                           Text="Test 12" />

                <TextBlock x:Name="Debug_TextBlock_13"
                           Style="{StaticResource MairaTextBlockStyle}"
                           Text="Test 13" />

            </StackPanel>

        </controls:MairaGroupBox>
        
    </StackPanel>

</UserControl>
