<UserControl x:Class="MarvinsAIRARefactored.Pages.GraphPage"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MarvinsAIRARefactored.Pages"
             xmlns:controls="clr-namespace:MarvinsAIRARefactored.Controls"
             xmlns:datacontext="clr-namespace:MarvinsAIRARefactored.DataContext"
             mc:Ignorable="d"
             d:DesignWidth="800">

    <UserControl.DataContext>
        <Binding Source="{x:Static datacontext:DataContext.Instance}" />
    </UserControl.DataContext>

    <StackPanel>

        <controls:MairaGroupHeader Label="{Binding Localization[Graph_UC]}" />

        <Grid x:Name="Grid">

            <Border x:Name="Border"
                    Margin="0,10,0,0"
                    BorderThickness="2"
                    BorderBrush="#FFF"
                    Background="#80000000"
                    CornerRadius="5">

                <Image x:Name="Image"
                       Height="401"
                       Width="3840"
                       HorizontalAlignment="Right"
                       RenderOptions.BitmapScalingMode="HighQuality" />

            </Border>

            <controls:MairaButton Margin="20"
                                  Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/missing-icon.png"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Bottom"
                                  Click="Target_MairaButton_Click">

                <controls:MairaButton.Style>

                    <Style TargetType="controls:MairaButton">

                        <Setter Property="Visibility"
                                Value="Collapsed" />

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=Grid}"
                                         Value="True">
                                <Setter Property="Visibility"
                                        Value="Visible" />
                            </DataTrigger>

                        </Style.Triggers>

                    </Style>

                </controls:MairaButton.Style>

            </controls:MairaButton>

        </Grid>

        <StackPanel x:Name="BottomPanel_StackPanel"
                    Tag="HideWhenGraphIsSoloed">

            <Grid Margin="0,10,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <controls:MairaComboBox Grid.Column="0"
                                        x:Name="Statistics_MairaComboBox"
                                        SelectedValue="{Binding Settings.GraphStatisticsLayerIndex, Mode=TwoWay}" />

                <StackPanel Grid.Column="1">

                    <TextBlock Style="{StaticResource MairaTextBlockStyle}"
                               Text="{Binding Localization[Minimum]}"
                               HorizontalAlignment="Center"
                               FontSize="10" />

                    <TextBlock Style="{StaticResource MairaTextBlockStyle}"
                               x:Name="Minimum_TextBlock"
                               HorizontalAlignment="Center"
                               Text="0.00" />

                </StackPanel>

                <StackPanel Grid.Column="2">

                    <TextBlock Style="{StaticResource MairaTextBlockStyle}"
                               Text="{Binding Localization[Maximum]}"
                               HorizontalAlignment="Center"
                               FontSize="10" />

                    <TextBlock Style="{StaticResource MairaTextBlockStyle}"
                               x:Name="Maximum_TextBlock"
                               HorizontalAlignment="Center"
                               Text="0.00" />

                </StackPanel>

                <StackPanel Grid.Column="3">

                    <TextBlock Style="{StaticResource MairaTextBlockStyle}"
                               Text="{Binding Localization[Average]}"
                               HorizontalAlignment="Center"
                               FontSize="10" />

                    <TextBlock Style="{StaticResource MairaTextBlockStyle}"
                               x:Name="Average_TextBlock"
                               HorizontalAlignment="Center"
                               Text="0.00" />

                </StackPanel>

                <StackPanel Grid.Column="4">

                    <TextBlock Style="{StaticResource MairaTextBlockStyle}"
                               Text="{Binding Localization[Variance]}"
                               HorizontalAlignment="Center"
                               FontSize="10" />

                    <TextBlock Style="{StaticResource MairaTextBlockStyle}"
                               x:Name="Variance_TextBlock"
                               HorizontalAlignment="Center"
                               Text="0.00" />

                </StackPanel>

                <StackPanel Grid.Column="5">

                    <TextBlock Style="{StaticResource MairaTextBlockStyle}"
                               Text="{Binding Localization[StandardDeviation]}"
                               HorizontalAlignment="Center"
                               FontSize="10" />

                    <TextBlock Style="{StaticResource MairaTextBlockStyle}"
                               x:Name="StandardDeviation_TextBlock"
                               HorizontalAlignment="Center"
                               Text="0.00" />

                </StackPanel>

            </Grid>

            <Grid Margin="0,20,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <controls:MairaSwitch Grid.Column="0"
                                      IsOn="{Binding Settings.GraphInputTorque, Mode=TwoWay}"
                                      Label="{Binding Localization[InputTorque]}" />

                <controls:MairaSwitch Grid.Column="2"
                                      IsOn="{Binding Settings.GraphOutputTorque, Mode=TwoWay}"
                                      Label="{Binding Localization[OutputTorque]}" />

            </Grid>

            <Grid Margin="0,10,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <controls:MairaSwitch Grid.Column="0"
                                      IsOn="{Binding Settings.GraphInputTorque60Hz, Mode=TwoWay}"
                                      Label="{Binding Localization[InputTorque60Hz]}" />

                <controls:MairaSwitch Grid.Column="2"
                                      IsOn="{Binding Settings.GraphInputLFE, Mode=TwoWay}"
                                      Label="{Binding Localization[InputLFE]}" />

            </Grid>

            <Grid Margin="0,10,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <controls:MairaSwitch Grid.Column="0"
                                      IsOn="{Binding Settings.GraphClutchPedalHaptics, Mode=TwoWay}"
                                      Label="{Binding Localization[ClutchPedalHaptics]}" />

                <controls:MairaSwitch Grid.Column="2"
                                      IsOn="{Binding Settings.GraphBrakePedalHaptics, Mode=TwoWay}"
                                      Label="{Binding Localization[BrakePedalHaptics]}" />

                <controls:MairaSwitch Grid.Column="4"
                                      IsOn="{Binding Settings.GraphThrottlePedalHaptics, Mode=TwoWay}"
                                      Label="{Binding Localization[ThrottlePedalHaptics]}" />

            </Grid>

            <Grid Margin="0,10,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <controls:MairaSwitch Grid.Column="0"
                                      IsOn="{Binding Settings.GraphTimerJitter, Mode=TwoWay}"
                                      Label="{Binding Localization[TimerJitter]}" />

            </Grid>

        </StackPanel>

    </StackPanel>

</UserControl>
