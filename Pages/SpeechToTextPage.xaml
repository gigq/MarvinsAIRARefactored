<UserControl x:Class="MarvinsALMUARefactored.Pages.SpeechToTextPage"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MarvinsALMUARefactored.Pages"
             xmlns:controls="clr-namespace:MarvinsALMUARefactored.Controls"
             xmlns:datacontext="clr-namespace:MarvinsALMUARefactored.DataContext"
             mc:Ignorable="d"
             d:DesignWidth="800">

    <UserControl.DataContext>
        <Binding Source="{x:Static datacontext:DataContext.Instance}" />
    </UserControl.DataContext>

    <StackPanel>

        <controls:MairaGroupBox Label="{Binding Localization[SpeechToText_UC]}">

            <StackPanel>

                <controls:MairaSwitch Margin="0"
                                      IsOn="{Binding Settings.SpeechToTextEnabled, Mode=TwoWay}"
                                      Label="{Binding Localization[Enabled]}" />

            </StackPanel>

        </controls:MairaGroupBox>

        <controls:MairaGroupBox Label="{Binding Localization[Language_UC]}">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <controls:MairaComboBox x:Name="Language_MairaComboBox"
                                        Grid.Column="0"
                                        SelectedValue="{Binding Settings.SpeechToTextLanguageCode, Mode=TwoWay}" />

            </Grid>

        </controls:MairaGroupBox>

        <controls:MairaGroupBox Label="{Binding Localization[OverlayWindow_UC]}">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Grid.Column="0"
                            Grid.ColumnSpan="3">

                    <controls:MairaSwitch IsOn="{Binding Settings.SpeechToTextShowOverlayWindowTitle, Mode=TwoWay}"
                                          Label="{Binding Localization[ShowOverlayWindowTitle]}" />

                    <controls:MairaSwitch Margin="0,10,0,0"
                                          IsOn="{Binding Settings.SpeechToTextMakeOverlayWindowDraggable, Mode=TwoWay}"
                                          Label="{Binding Localization[MakeOverlayWindowDraggable]}" />
                </StackPanel>

                <controls:MairaKnob Grid.Row="0"
                                    Grid.Column="4"
                                    Label="{Binding Localization[OverlayWindowScale]}"
                                    Value="{Binding Settings.SpeechToTextOverlayWindowScale, Mode=TwoWay}"
                                    ValueString="{Binding Settings.SpeechToTextOverlayWindowScaleString}"
                                    StepSize="0.05"
                                    DefaultValue="1" />

                <controls:MairaButton x:Name="ResetOverlayWindow_MairaButton"
                                      Grid.Row="2"
                                      Grid.Column="0"
                                      Grid.ColumnSpan="5"
                                      Icon="/MarvinsALMUARefactored;component/Artwork/Buttons/reset.png"
                                      Label="{Binding Localization[ResetOverlayWindow]}"
                                      Click="ResetOverlayWindow_MairaButton_Click" />

            </Grid>

        </controls:MairaGroupBox>

    </StackPanel>

</UserControl>
