<UserControl x:Class="MarvinsALMUARefactored.Pages.AppSettingsPage"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MarvinsALMUARefactored.Pages"
             xmlns:controls="clr-namespace:MarvinsALMUARefactored.Controls"
             xmlns:datacontext="clr-namespace:MarvinsALMUARefactored.DataContext"
             mc:Ignorable="d"
             d:DesignWidth="800">

    <UserControl.DataContext>
        <Binding Source="{x:Static datacontext:DataContext.Instance}" />
    </UserControl.DataContext>

    <StackPanel>

        <controls:MairaGroupBox Label="Simulation"
                                Tag="HideIfAdminBoxx">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <controls:MairaComboBox x:Name="Simulator_MairaComboBox"
                                        Grid.Row="0"
                                        SelectedValue="{Binding Settings.AppSelectedSimulator, Mode=TwoWay}" />

                <TextBlock x:Name="SimulatorSupportNote_TextBlock"
                           Grid.Row="1"
                           Margin="0,10,0,0"
                           FontSize="16"
                           TextWrapping="Wrap"
                           Foreground="#bbbbbb"
                           Style="{StaticResource MairaTextBlockStyle}" />

            </Grid>

        </controls:MairaGroupBox>

        <controls:MairaGroupBox Label="{Binding Localization[Language_UC]}"
                                Tag="HideIfAdminBoxx"
                                HelpTopic="advanced/app-settings/#language">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <controls:MairaComboBox x:Name="Language_MairaComboBox"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="1"
                                        SelectedValue="{Binding Settings.AppCurrentLanguageCode, Mode=TwoWay}" />

            </Grid>

        </controls:MairaGroupBox>

        <controls:MairaGroupBox Label="{Binding Localization[DefaultPage_UC]}"
                                Tag="HideIfAdminBoxx"
                                HelpTopic="advanced/app-settings/#default-page">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <controls:MairaComboBox x:Name="DefaultPage_MairaComboBox"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="1"
                                        SelectedValue="{Binding Settings.AppDefaultPage, Mode=TwoWay}" />

            </Grid>

        </controls:MairaGroupBox>

        <controls:MairaGroupBox Label="{Binding Localization[AppWindow_UC]}"
                                HelpTopic="advanced/app-settings/#app-window">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <controls:MairaSwitch Grid.Row="0"
                                      Grid.Column="0"
                                      Grid.ColumnSpan="3"
                                      Margin="0"
                                      IsOn="{Binding Settings.AppTopmostWindowEnabled, Mode=TwoWay}"
                                      Label="{Binding Localization[TopmostWindow]}" />

                <controls:MairaSwitch Grid.Row="1"
                                      Grid.Column="0"
                                      Grid.ColumnSpan="3"
                                      Margin="0,10,0,0"
                                      IsOn="{Binding Settings.AppRememberWindowPositionAndSize, Mode=TwoWay}"
                                      Label="{Binding Localization[RememberWindowPositionAndSize]}" />

                <controls:MairaSwitch Grid.Row="2"
                                      Grid.Column="0"
                                      Grid.ColumnSpan="3"
                                      Margin="0,10,0,0"
                                      IsOn="{Binding Settings.AppStartWithWindows, Mode=TwoWay}"
                                      Label="{Binding Localization[StartWithWindows]}" />

                <controls:MairaSwitch Grid.Row="3"
                                      Grid.Column="0"
                                      Grid.ColumnSpan="3"
                                      Margin="0,10,0,0"
                                      IsOn="{Binding Settings.AppStartMinimized, Mode=TwoWay}"
                                      Label="{Binding Localization[StartMinimized]}" />

                <controls:MairaSwitch Grid.Row="4"
                                      Grid.Column="0"
                                      Grid.ColumnSpan="3"
                                      Margin="0,10,0,0"
                                      IsOn="{Binding Settings.AppMinimizeToSystemTray, Mode=TwoWay}"
                                      Label="{Binding Localization[MinimizeToSystemTray]}" />

                <controls:MairaKnob Grid.Row="0"
                                    Grid.Column="4"
                                    Grid.RowSpan="5"
                                    Label="{Binding Localization[UIScale]}"
                                    Value="{Binding Settings.AppUIScale, Mode=TwoWay}"
                                    ValueString="{Binding Settings.AppUIScaleString}"
                                    StepSize="0.05"
                                    DefaultValue="1" />

            </Grid>

        </controls:MairaGroupBox>

        <controls:MairaGroupBox Label="{Binding Localization[CloudService_UC]}"
                                Tag="HideIfAdminBoxx"
                                HelpTopic="advanced/app-settings/#cloud-service">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <controls:MairaSwitch Grid.Column="0"
                                      Grid.ColumnSpan="3"
                                      IsOn="{Binding Settings.AppCheckForUpdates, Mode=TwoWay}"
                                      Label="{Binding Localization[CheckForUpdates]}"
                                      VerticalAlignment="Top" />

                <controls:MairaButton x:Name="CheckNow_MairaButton"
                                      Grid.Column="4"
                                      Label="{Binding Localization[CheckNow]}"
                                      Icon="/MarvinsALMUARefactored;component/Artwork/Buttons/reset.png"
                                      Click="CheckNow_MairaButton_Click" />

            </Grid>

        </controls:MairaGroupBox>
    
        <controls:MairaGroupBox Label="{Binding Localization[CPUAffinity_UC]}"
                                Tag="HideIfAdminBoxx"
                                HelpTopic="advanced/app-settings/#cpu-affinity">

            <UniformGrid x:Name="CpuAffinityPanel"
                         Columns="4">

                <!-- CPU affinity checkboxes will be dynamically added here -->

            </UniformGrid>

        </controls:MairaGroupBox>

    </StackPanel>

</UserControl>
