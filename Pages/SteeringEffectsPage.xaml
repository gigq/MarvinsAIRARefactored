<UserControl x:Class="MarvinsAIRARefactored.Pages.SteeringEffectsPage"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MarvinsAIRARefactored.Controls"
             xmlns:controls="clr-namespace:MarvinsAIRARefactored.Controls"
             xmlns:datacontext="clr-namespace:MarvinsAIRARefactored.DataContext"
             mc:Ignorable="d"
             d:DesignWidth="800">

    <UserControl.DataContext>
        <Binding Source="{x:Static datacontext:DataContext.Instance}" />
    </UserControl.DataContext>

    <StackPanel>

        <controls:MairaGroupHeader Label="{Binding Localization[CalibrationFile_UC]}" />

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="5" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <controls:MairaComboBox x:Name="CalibrationFileName_MairaComboBox"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="3"
                                    Label=""
                                    SelectedValue="{Binding Settings.SteeringEffectsCalibrationFileName, Mode=TwoWay}" />

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Grid.ColumnSpan="3"
                       d:Text="Just a test to see what this line looks like."
                       Foreground="#ff5b2e" />

        </Grid>

        <controls:MairaGroupHeader Label="{Binding Localization[Understeer_UC]}" />

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:MairaKnob Grid.Column="0"
                                Label="{Binding Localization[MinimumThreshold]}"
                                Value="{Binding Settings.SteeringEffectsUndersteerMinimumThreshold, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsUndersteerMinimumThresholdString}"
                                StepSize="0.01"
                                ContextSwitches="{Binding Settings.SteeringEffectsUndersteerMinimumThresholdContextSwitches}"
                                PlusButtonMappings="{Binding Settings.SteeringEffectsUndersteerMinimumThresholdPlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.SteeringEffectsUndersteerMinimumThresholdMinusButtonMappings}"
                                DefaultValue="0.05" />

            <controls:MairaKnob Grid.Column="2"
                                Label="{Binding Localization[MaximumThreshold]}"
                                Value="{Binding Settings.SteeringEffectsUndersteerMaximumThreshold, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsUndersteerMaximumThresholdString}"
                                StepSize="0.01"
                                ContextSwitches="{Binding Settings.SteeringEffectsUndersteerMaximumThresholdContextSwitches}"
                                PlusButtonMappings="{Binding Settings.SteeringEffectsUndersteerMaximumThresholdPlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.SteeringEffectsUndersteerMaximumThresholdMinusButtonMappings}"
                                DefaultValue="0.13" />

        </Grid>

        <controls:MairaGroupHeader Label="{Binding Localization[Oversteer_UC]}" />

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:MairaKnob Grid.Column="0"
                                Label="{Binding Localization[MinimumThreshold]}"
                                Value="{Binding Settings.SteeringEffectsOversteerMinimumThreshold, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsOversteerMinimumThresholdString}"
                                StepSize="0.01"
                                ContextSwitches="{Binding Settings.SteeringEffectsOversteerMinimumThresholdContextSwitches}"
                                PlusButtonMappings="{Binding Settings.SteeringEffectsOversteerMinimumThresholdPlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.SteeringEffectsOversteerMinimumThresholdMinusButtonMappings}"
                                DefaultValue="0.01" />

            <controls:MairaKnob Grid.Column="2"
                                Label="{Binding Localization[MaximumThreshold]}"
                                Value="{Binding Settings.SteeringEffectsOversteerMaximumThreshold, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsOversteerMaximumThresholdString}"
                                StepSize="0.01"
                                ContextSwitches="{Binding Settings.SteeringEffectsOversteerMaximumThresholdContextSwitches}"
                                PlusButtonMappings="{Binding Settings.SteeringEffectsOversteerMaximumThresholdPlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.SteeringEffectsOversteerMaximumThresholdMinusButtonMappings}"
                                DefaultValue="0.5" />

        </Grid>

        <controls:MairaGroupHeader Label="{Binding Localization[CalibrationGraph_UC]}" />

        <Grid>

            <Border BorderThickness="2"
                    BorderBrush="#FFF"
                    Background="#80000000"
                    CornerRadius="5"
                    Padding="0,20,0,20">

                <Image x:Name="Calibration_Image"
                       Height="400"
                       Width="900"
                       RenderOptions.BitmapScalingMode="HighQuality" />

            </Border>

            <TextBlock x:Name="CalibrationProgress_TextBlock"
                       Style="{StaticResource MairaTextBlockStyle}"
                       Text="Progress: 100%"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Top"
                       Margin="0,82,0,0"
                       Foreground="White"
                       Background="Black"
                       Padding="20,2,20,6" />

        </Grid>

        <controls:MairaGroupHeader Label="{Binding Localization[UndersteerWheelVibrationEffect_UC]}" />

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:MairaComboBox x:Name="UndersteerWheelVibrationPattern_MairaComboBox"
                                    Grid.Column="0"
                                    Label="{Binding Localization[VibrationPattern]}"
                                    SelectedValue="{Binding Settings.SteeringEffectsUndersteerWheelVibrationPattern, Mode=TwoWay}"
                                    ContextSwitches="{Binding Settings.SteeringEffectsUndersteerWheelVibrationPatternContextSwitches}" />

            <controls:MairaKnob Grid.Column="2"
                                Label="{Binding Localization[Strength]}"
                                Value="{Binding Settings.SteeringEffectsUndersteerWheelVibrationStrength, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsUndersteerWheelVibrationStrengthString}"
                                StepSize="0.01"
                                ContextSwitches="{Binding Settings.SteeringEffectsUndersteerWheelVibrationStrengthContextSwitches}"
                                PlusButtonMappings="{Binding Settings.SteeringEffectsUndersteerWheelVibrationStrengthPlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.SteeringEffectsUndersteerWheelVibrationStrengthMinusButtonMappings}"
                                DefaultValue="0.1" />

        </Grid>

        <Grid Margin="0,20,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:MairaKnob Grid.Column="0"
                                Label="{Binding Localization[MinimumFrequency]}"
                                Value="{Binding Settings.SteeringEffectsUndersteerWheelVibrationMinimumFrequency, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsUndersteerWheelVibrationMinimumFrequencyString}"
                                StepSize="1"
                                ContextSwitches="{Binding Settings.SteeringEffectsUndersteerWheelVibrationMinimumFrequencyContextSwitches}"
                                PlusButtonMappings="{Binding Settings.SteeringEffectsUndersteerWheelVibrationMinimumFrequencyPlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.SteeringEffectsUndersteerWheelVibrationMinimumFrequencyMinusButtonMappings}"
                                DefaultValue="15" />

            <controls:MairaKnob Grid.Column="2"
                                Label="{Binding Localization[MaximumFrequency]}"
                                Value="{Binding Settings.SteeringEffectsUndersteerWheelVibrationMaximumFrequency, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsUndersteerWheelVibrationMaximumFrequencyString}"
                                StepSize="1"
                                ContextSwitches="{Binding Settings.SteeringEffectsUndersteerWheelVibrationMaximumFrequencyContextSwitches}"
                                PlusButtonMappings="{Binding Settings.SteeringEffectsUndersteerWheelVibrationMaximumFrequencyPlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.SteeringEffectsUndersteerWheelVibrationMaximumFrequencyMinusButtonMappings}"
                                DefaultValue="50" />

            <controls:MairaKnob Grid.Column="4"
                                Label="{Binding Localization[Curve]}"
                                Value="{Binding Settings.SteeringEffectsUndersteerWheelVibrationCurve, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsUndersteerWheelVibrationCurveString}"
                                StepSize="0.01"
                                ContextSwitches="{Binding Settings.SteeringEffectsUndersteerWheelVibrationCurveContextSwitches}"
                                PlusButtonMappings="{Binding Settings.SteeringEffectsUndersteerWheelVibrationCurvePlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.SteeringEffectsUndersteerWheelVibrationCurveMinusButtonMappings}"
                                ShowCurve="True"
                                DefaultValue="0.25" />

        </Grid>

        <controls:MairaGroupHeader Label="{Binding Localization[UndersteerWheelConstantForceEffect_UC]}" />

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:MairaComboBox x:Name="UndersteerWheelConstantForceDirection_MairaComboBox"
                                    Grid.Column="0"
                                    Label="{Binding Localization[Direction]}"
                                    SelectedValue="{Binding Settings.SteeringEffectsUndersteerWheelConstantForceDirection, Mode=TwoWay}"
                                    ContextSwitches="{Binding Settings.SteeringEffectsUndersteerWheelConstantForceDirectionContextSwitches}" />

            <controls:MairaKnob Grid.Column="2"
                                Label="{Binding Localization[Strength]}"
                                Value="{Binding Settings.SteeringEffectsUndersteerWheelConstantForceStrength, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsUndersteerWheelConstantForceStrengthString}"
                                StepSize="0.01"
                                ContextSwitches="{Binding Settings.SteeringEffectsUndersteerWheelConstantForceStrengthContextSwitches}"
                                PlusButtonMappings="{Binding Settings.SteeringEffectsUndersteerWheelConstantForceStrengthPlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.SteeringEffectsUndersteerWheelConstantForceStrengthMinusButtonMappings}"
                                DefaultValue="0.1" />

        </Grid>

        <controls:MairaGroupHeader Label="{Binding Localization[UndersteerPedalVibrationEffect_UC]}" />

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:MairaKnob Grid.Column="0"
                                Label="{Binding Localization[MinimumFrequency]}"
                                Value="{Binding Settings.SteeringEffectsUndersteerPedalVibrationMinimumFrequency, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsUndersteerPedalVibrationMinimumFrequencyString}"
                                StepSize="0.01"
                                ContextSwitches="{Binding Settings.SteeringEffectsUndersteerPedalVibrationMinimumFrequencyContextSwitches}"
                                PlusButtonMappings="{Binding Settings.SteeringEffectsUndersteerPedalVibrationMinimumFrequencyPlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.SteeringEffectsUndersteerPedalVibrationMinimumFrequencyMinusButtonMappings}"
                                DefaultValue="0" />

            <controls:MairaKnob Grid.Column="2"
                                Label="{Binding Localization[MaximumFrequency]}"
                                Value="{Binding Settings.SteeringEffectsUndersteerPedalVibrationMaximumFrequency, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsUndersteerPedalVibrationMaximumFrequencyString}"
                                StepSize="0.01"
                                ContextSwitches="{Binding Settings.SteeringEffectsUndersteerPedalVibrationMaximumFrequencyContextSwitches}"
                                PlusButtonMappings="{Binding Settings.SteeringEffectsUndersteerPedalVibrationMaximumFrequencyPlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.SteeringEffectsUndersteerPedalVibrationMaximumFrequencyMinusButtonMappings}"
                                DefaultValue="1" />

            <controls:MairaKnob Grid.Column="4"
                                Label="{Binding Localization[Curve]}"
                                Value="{Binding Settings.SteeringEffectsUndersteerPedalVibrationCurve, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsUndersteerPedalVibrationCurveString}"
                                StepSize="0.01"
                                ContextSwitches="{Binding Settings.SteeringEffectsUndersteerPedalVibrationCurveContextSwitches}"
                                PlusButtonMappings="{Binding Settings.SteeringEffectsUndersteerPedalVibrationCurvePlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.SteeringEffectsUndersteerPedalVibrationCurveMinusButtonMappings}"
                                ShowCurve="True"
                                DefaultValue="0" />

        </Grid>

        <controls:MairaGroupHeader Label="{Binding Localization[OversteerWheelVibrationEffect_UC]}" />

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:MairaComboBox x:Name="OversteerWheelVibrationPattern_MairaComboBox"
                                    Grid.Column="0"
                                    Label="{Binding Localization[VibrationPattern]}"
                                    SelectedValue="{Binding Settings.SteeringEffectsOversteerWheelVibrationPattern, Mode=TwoWay}"
                                    ContextSwitches="{Binding Settings.SteeringEffectsOversteerWheelVibrationPatternContextSwitches}" />

            <controls:MairaKnob Grid.Column="2"
                                Label="{Binding Localization[Strength]}"
                                Value="{Binding Settings.SteeringEffectsOversteerWheelVibrationStrength, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsOversteerWheelVibrationStrengthString}"
                                StepSize="0.01"
                                ContextSwitches="{Binding Settings.SteeringEffectsOversteerWheelVibrationStrengthContextSwitches}"
                                PlusButtonMappings="{Binding Settings.SteeringEffectsOversteerWheelVibrationStrengthPlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.SteeringEffectsOversteerWheelVibrationStrengthMinusButtonMappings}"
                                DefaultValue="0.1" />

        </Grid>

        <Grid Margin="0,20,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:MairaKnob Grid.Column="0"
                                Label="{Binding Localization[MinimumFrequency]}"
                                Value="{Binding Settings.SteeringEffectsOversteerWheelVibrationMinimumFrequency, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsOversteerWheelVibrationMinimumFrequencyString}"
                                StepSize="1"
                                ContextSwitches="{Binding Settings.SteeringEffectsOversteerWheelVibrationMinimumFrequencyContextSwitches}"
                                PlusButtonMappings="{Binding Settings.SteeringEffectsOversteerWheelVibrationMinimumFrequencyPlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.SteeringEffectsOversteerWheelVibrationMinimumFrequencyMinusButtonMappings}"
                                DefaultValue="15" />

            <controls:MairaKnob Grid.Column="2"
                                Label="{Binding Localization[MaximumFrequency]}"
                                Value="{Binding Settings.SteeringEffectsOversteerWheelVibrationMaximumFrequency, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsOversteerWheelVibrationMaximumFrequencyString}"
                                StepSize="1"
                                ContextSwitches="{Binding Settings.SteeringEffectsOversteerWheelVibrationMaximumFrequencyContextSwitches}"
                                PlusButtonMappings="{Binding Settings.SteeringEffectsOversteerWheelVibrationMaximumFrequencyPlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.SteeringEffectsOversteerWheelVibrationMaximumFrequencyMinusButtonMappings}"
                                DefaultValue="50" />

            <controls:MairaKnob Grid.Column="4"
                                Label="{Binding Localization[Curve]}"
                                Value="{Binding Settings.SteeringEffectsOversteerWheelVibrationCurve, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsOversteerWheelVibrationCurveString}"
                                StepSize="0.01"
                                ContextSwitches="{Binding Settings.SteeringEffectsOversteerWheelVibrationCurveContextSwitches}"
                                PlusButtonMappings="{Binding Settings.SteeringEffectsOversteerWheelVibrationCurvePlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.SteeringEffectsOversteerWheelVibrationCurveMinusButtonMappings}"
                                ShowCurve="True"
                                DefaultValue="0.25" />

        </Grid>

        <controls:MairaGroupHeader Label="{Binding Localization[OversteerWheelConstantForceEffect_UC]}" />

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:MairaComboBox x:Name="OversteerWheelConstantForceDirection_MairaComboBox"
                                    Grid.Column="0"
                                    Label="{Binding Localization[Direction]}"
                                    SelectedValue="{Binding Settings.SteeringEffectsOversteerWheelConstantForceDirection, Mode=TwoWay}"
                                    ContextSwitches="{Binding Settings.SteeringEffectsOversteerWheelConstantForceDirectionContextSwitches}" />

            <controls:MairaKnob Grid.Column="2"
                                Label="{Binding Localization[Strength]}"
                                Value="{Binding Settings.SteeringEffectsOversteerWheelConstantForceStrength, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsOversteerWheelConstantForceStrengthString}"
                                StepSize="0.01"
                                ContextSwitches="{Binding Settings.SteeringEffectsOversteerWheelConstantForceStrengthContextSwitches}"
                                PlusButtonMappings="{Binding Settings.SteeringEffectsOversteerWheelConstantForceStrengthPlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.SteeringEffectsOversteerWheelConstantForceStrengthMinusButtonMappings}"
                                DefaultValue="0.5" />

        </Grid>

        <controls:MairaGroupHeader Label="{Binding Localization[OversteerPedalVibrationEffect_UC]}" />

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:MairaKnob Grid.Column="0"
                                Label="{Binding Localization[MinimumFrequency]}"
                                Value="{Binding Settings.SteeringEffectsOversteerPedalVibrationMinimumFrequency, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsOversteerPedalVibrationMinimumFrequencyString}"
                                StepSize="0.01"
                                ContextSwitches="{Binding Settings.SteeringEffectsOversteerPedalVibrationMinimumFrequencyContextSwitches}"
                                PlusButtonMappings="{Binding Settings.SteeringEffectsOversteerPedalVibrationMinimumFrequencyPlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.SteeringEffectsOversteerPedalVibrationMinimumFrequencyMinusButtonMappings}"
                                DefaultValue="0" />

            <controls:MairaKnob Grid.Column="2"
                                Label="{Binding Localization[MaximumFrequency]}"
                                Value="{Binding Settings.SteeringEffectsOversteerPedalVibrationMaximumFrequency, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsOversteerPedalVibrationMaximumFrequencyString}"
                                StepSize="0.01"
                                ContextSwitches="{Binding Settings.SteeringEffectsOversteerPedalVibrationMaximumFrequencyContextSwitches}"
                                PlusButtonMappings="{Binding Settings.SteeringEffectsOversteerPedalVibrationMaximumFrequencyPlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.SteeringEffectsOversteerPedalVibrationMaximumFrequencyMinusButtonMappings}"
                                DefaultValue="1" />

            <controls:MairaKnob Grid.Column="4"
                                Label="{Binding Localization[Curve]}"
                                Value="{Binding Settings.SteeringEffectsOversteerPedalVibrationCurve, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsOversteerPedalVibrationCurveString}"
                                StepSize="0.01"
                                ContextSwitches="{Binding Settings.SteeringEffectsOversteerPedalVibrationCurveContextSwitches}"
                                PlusButtonMappings="{Binding Settings.SteeringEffectsOversteerPedalVibrationCurvePlusButtonMappings}"
                                MinusButtonMappings="{Binding Settings.SteeringEffectsOversteerPedalVibrationCurveMinusButtonMappings}"
                                ShowCurve="True"
                                DefaultValue="0" />

        </Grid>

        <controls:MairaGroupHeader Label="{Binding Localization[GripOMeter_UC]}" />

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <controls:MairaSwitch Grid.Row="0"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="3"
                                  Margin="0"
                                  IsOn="{Binding Settings.SteeringEffectsShowGripOMeterWindow, Mode=TwoWay}"
                                  Label="{Binding Localization[ShowGripOMeter]}" />

            <controls:MairaSwitch Grid.Row="1"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="3"
                                  Margin="0,10,0,0"
                                  IsOn="{Binding Settings.SteeringEffectsMakeGripOMeterDraggable, Mode=TwoWay}"
                                  Label="{Binding Localization[MakeGripOMeterDraggable]}" />

            <controls:MairaButton x:Name="ResetGripOMeter_MairaButton"
                                  Grid.Row="2"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="3"
                                  Margin="0,10,0,0"
                                  Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/reset.png"
                                  Label="{Binding Localization[ResetGripOMeter]}"
                                  LabelOnRight="True"
                                  Click="ResetGripOMeter_MairaButton_Click" />

            <controls:MairaKnob Grid.Row="0"
                                Grid.Column="4"
                                Grid.RowSpan="5"
                                VerticalAlignment="Center"
                                Margin="0,0,0,10"
                                Label="{Binding Localization[GripOMeterScale]}"
                                Value="{Binding Settings.SteeringEffectsGripOMeterWindowScale, Mode=TwoWay}"
                                ValueString="{Binding Settings.SteeringEffectsGripOMeterWindowScaleString}"
                                StepSize="0.05"
                                DefaultValue="1" />

        </Grid>

        <controls:MairaGroupHeader Label="{Binding Localization[Calibration_UC]}" />

        <TextBlock x:Name="NotOnCentripetalCircuitTrack_TextBlock"
                   Text="{Binding Localization[NotOnCentripetalCircuitTrack]}"
                   Foreground="#FFFFFF"
                   Background="#FF4C00"
                   Padding="20,2,20,4"
                   TextAlignment="Center" />

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:MairaButton x:Name="RunCalibration_MairaButton"
                                  Grid.Row="0"
                                  Grid.Column="1"
                                  Label="{Binding Localization[RunCalibration]}"
                                  Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/run-calibration.png"
                                  Click="RunCalibration_MairaButton_Click" />

            <controls:MairaButton x:Name="StopCalibration_MairaButton"
                                  Grid.Row="0"
                                  Grid.Column="3"
                                  Label="{Binding Localization[StopCalibration]}"
                                  Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/stop-calibration.png"
                                  Click="StopCalibration_MairaButton_Click" />

        </Grid>

        <UniformGrid Columns="4"
                     Margin="0,20,0,0">

            <UniformGrid.Resources>
                <Style TargetType="controls:MairaButton">
                    <Setter Property="Margin"
                            Value="0,20,0,0" />
                </Style>
            </UniformGrid.Resources>

            <controls:MairaButton Label="{Binding Localization[SteeringWheelLeft]}"
                                  Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/steering-wheel-left.png"
                                  Click="SteeringWheelLeft_MairaButton_Click" />

            <controls:MairaButton Label="{Binding Localization[SteeringWheelCenter]}"
                                  Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/steering-wheel-center.png"
                                  Click="SteeringWheelCenter_MairaButton_Click" />

            <controls:MairaButton Label="{Binding Localization[SteeringWheelRight]}"
                                  Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/steering-wheel-right.png"
                                  Click="SteeringWheelRight_MairaButton_Click" />

            <controls:MairaButton Label="{Binding Localization[SteeringWheel90Left]}"
                                  Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/steering-wheel-90-left.png"
                                  Click="SteeringWheel90Left_MairaButton_Click" />

            <controls:MairaButton Label="{Binding Localization[MinThrottle]}"
                                  Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/pedal-minimum.png"
                                  Click="MinThrottle_MairaButton_Click" />

            <controls:MairaButton Label="{Binding Localization[MaxThrottle]}"
                                  Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/pedal-maximum.png"
                                  Click="MaxThrottle_MairaButton_Click" />

            <controls:MairaButton Label="{Binding Localization[ShiftUp]}"
                                  Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/shift-up.png"
                                  Click="ShiftUp_MairaButton_Click" />

            <controls:MairaButton Label="{Binding Localization[ShiftDown]}"
                                  Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/shift-down.png"
                                  Click="ShiftDown_MairaButton_Click" />

            <controls:MairaButton Label="{Binding Localization[MinBrake]}"
                                  Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/pedal-minimum.png"
                                  Click="MinBrake_MairaButton_Click" />

            <controls:MairaButton Label="{Binding Localization[MaxBrake]}"
                                  Icon="/MarvinsAIRARefactored;component/Artwork/Buttons/pedal-maximum.png"
                                  Click="MaxBrake_MairaButton_Click" />

        </UniformGrid>

    </StackPanel>

</UserControl>
